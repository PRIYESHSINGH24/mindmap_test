rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: string (optional)
    //   - lastLogin: string (optional)
    //
    // Collection: problems
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - Owner UID
    //   - title: string (required)
    //   - platform: string (optional)
    //   - url: string (optional)
    //   - difficulty: string (required) - Easy, Medium, Hard
    //   - tags: list (optional) - Array of strings
    //   - dateSolved: string (optional)
    //   - timeTaken: number (optional)
    //   - attempts: number (optional)
    //   - status: string (required) - Solved, Revision Pending, Failed
    //   - createdAt: string (optional)
    //   - updatedAt: string (optional)
    //   - smartTags: list (optional)
    //
    // Collection: solutions
    // Document ID: auto-generated
    // Fields:
    //   - problemId: string (required)
    //   - uid: string (required)
    //   - language: string (required)
    //   - code: string (required)
    //   - version: number (optional)
    //   - createdAt: string (optional)
    //
    // [Other collections following similar ownership-based patterns]

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'email', 'photoURL', 'createdAt', 'lastLogin']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.uid == request.auth.uid;
    }

    function isValidProblem(data) {
      return data.keys().hasAll(['uid', 'title', 'difficulty', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.difficulty in ['Easy', 'Medium', 'Hard'] &&
             data.status in ['Solved', 'Revision Pending', 'Failed'] &&
             data.uid == request.auth.uid;
    }

    function isValidSolution(data) {
      return data.keys().hasAll(['problemId', 'uid', 'language', 'code']) &&
             data.code is string && data.code.size() < 50000 &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /problems/{problemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidProblem(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidProblem(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /solutions/{solutionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSolution(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSolution(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && request.resource.data.content is string;
      allow update: if isDocOwner() && uidNotModified() && request.resource.data.content is string;
      allow delete: if isDocOwner();
    }

    match /revisions/{revisionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /collections/{collectionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
